{
  "name": "Pet Care Game - Ralph Development",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.formatting.provider": "black",
        "python.analysis.typeCheckingMode": "basic",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  },

  "postCreateCommand": "pip install --upgrade pip && pip install -r scripts/ralph/requirements.txt",

  "remoteUser": "vscode",

  "mounts": [
    "source=${localWorkspaceFolder}/scripts/ralph,target=/workspace/scripts/ralph,type=bind,consistency=cached"
  ],

  "forwardPorts": [8000, 3000],

  "runArgs": ["--name", "pet-care-ralph-dev"]
}
