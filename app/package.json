{
  "name": "lillys-box",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "Jogo 2D infantil para Android usando React Native - cuidar de animais domésticos",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "EXPO_PUBLIC_BUILD_PLATFORM=web expo start --web",
    "build:web": "EXPO_PUBLIC_BUILD_PLATFORM=web expo export --platform web",
    "build:android:apk": "node scripts/buildAndroidApk.js",
    "build:android:bundle": "npx eas-cli build --platform android --profile production --non-interactive",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "maestro test e2e/flow.yaml",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "check-locale": "node scripts/check-locale-keys.js",
    "check-sounds": "node ../scripts/check-sounds.js"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "3.0.1",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-native/assets-registry": "^0.84.1",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.5",
    "@sentry/react-native": "^8.3.0",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.5",
    "expo-asset": "~55.0.9",
    "expo-av": "^13.10.6",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "^55.0.16",
    "expo-haptics": "~55.0.8",
    "expo-image-picker": "~55.0.11",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.6",
    "expo-status-bar": "~55.0.4",
    "firebase": "^12.9.0",
    "i18next": "^25.8.18",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.77.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-google-mobile-ads": "^16.3.0",
    "react-native-reanimated": "~4.2.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.6.4",
    "react-native-worklets": "^0.7.2",
    "socket.io-client": "^4.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-flow": "^7.27.1",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@types/react": "~18.2.45",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-jest": "^30.3.0",
    "babel-preset-expo": "~55.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-expo": "55.0.9",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.0",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.1.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "private": true
}
