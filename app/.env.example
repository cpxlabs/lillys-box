# Firebase — required for review sync (Firestore + Storage)
# Get these from Firebase Console > Project Settings > Your Apps > Web App
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Sentry — get your DSN from https://sentry.io/settings/hitss-40/projects/pet-care-game/keys/
EXPO_PUBLIC_SENTRY_DSN=

# GIF Search — get a free key from https://tenor.com/developer/keyregistration
EXPO_PUBLIC_TENOR_API_KEY=

# Google OAuth — get your Web Client ID from Google Cloud Console > APIs & Services > Credentials
# Docs: docs/GOOGLE_OAUTH_SETUP.md
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# AdMob — get ad unit IDs from https://admob.google.com
# Set EXPO_PUBLIC_ADS_TEST_MODE=false in production; leave blank to fall back to Google test IDs in dev.
# A startup assertion will throw if test IDs are detected when ADS_TEST_MODE=false.
EXPO_PUBLIC_ADS_TEST_MODE=true
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID_ID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID_ID=
EXPO_PUBLIC_ADMOB_BANNER_IOS_ID=
