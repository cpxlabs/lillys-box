{
  "name": "lillys-box-backend",
  "version": "0.1.0",
  "description": "Fastify API backend for Lilly's Box (merged servers)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "muito:dev": "ts-node --transpile-only server/src/index.ts",
    "muito:start": "node server/dist/index.js",
    "muito:build": "tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "express": "^4.18.2",
    "fastify": "^5.7.4",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "ts-node": "^10.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.1.3",
    "vitest": "^4.0.18"
  }
}
