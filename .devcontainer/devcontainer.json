{
  "name": "Lilly's Box",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },

  "remoteUser": "vscode",

  "forwardPorts": [8000, 3000],

  "runArgs": ["--name", "pet-care-dev"]
}
