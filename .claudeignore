# Claude Code ignore file - excludes files from context to reduce token usage

# Dependencies
node_modules/
pnpm-lock.yaml
package-lock.json

# Build outputs
dist/
web-build/
.expo/
build/
android/
ios/

# Cache and temporary files
.metro-health-check*
*.cache
.DS_Store

# Environment files (secrets)
.env*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/

# Native build artifacts
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Large/binary files
assets/sprites/**/*.png
assets/sprites/**/*.jpg
assets/fonts/**

# Development helpers
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Documentation (reference, not code)
docs/

# Git and version control
.git/
.gitignore

# Claude Code session files
.claude-session
*.claude-context
